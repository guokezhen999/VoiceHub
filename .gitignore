# ==========================================
# Git Ignore Config for Space Shuttle App Workspace
# ==========================================

# OS/System Files
.DS_Store
**/.DS_Store
Thumbs.db

# IDEs and Editors
.idea/
.vscode/
*.iml
*.ipr
*.iws
.history/
**/.cache/

# AI Tools and Assistant Metadata
.antigravitycli/
.claude/
.qoder/
.vscode/

# Compiled Binaries (Very Large, platform-specific)
bin/
**/bin/

# Build Directories (C++ and Flutter build outputs)
**/build/
**/build-*/
opus_mt/build/
sherpa-onnx/build/
sherpa-onnx/build-ios/
sherpa-onnx/build-swift-macos/

# Flutter specific ignores (in addition to voice_app/.gitignore)
voice_app/.dart_tool/
voice_app/.flutter-plugins
voice_app/.flutter-plugins-dependencies
voice_app/.pub-cache/
voice_app/.pub/
voice_app/build/
voice_app/android/app/debug/
voice_app/android/app/profile/
voice_app/android/app/release/

# Llama Flutter specific ignores
llama/flutter/llamacpp_macos/.dart_tool/
llama/flutter/llamacpp_macos/.flutter-plugins
llama/flutter/llamacpp_macos/.flutter-plugins-dependencies
llama/flutter/llamacpp_macos/.pub-cache/
llama/flutter/llamacpp_macos/.pub/

# Large Files (dylibs, ML models, Archive packages)
*.dylib
model/

# Audio/Wav test datasets (Large audio files)
wav/
*.wav
