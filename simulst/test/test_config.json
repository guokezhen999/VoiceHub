{
  "export_dir": "../../model/tmk/speechllm/grpo-comet",
  "enable_transcribe": true,
  "enable_translate": true,
  "transcribe_lang": "auto",
  "translate_lang": "English",
  "num_chunks": 1,
  "max_llm_kv_segments_base": 64,
  "encoder_provider": "auto",
  "encoder_num_threads": 1,
  "n_ctx": 8192,
  "n_batch": 512,
  "n_threads": 4,
  "n_gpu_layers": -1,
  "max_new_tokens": 200,
  "repetition_penalty": 1.0,
  "first_token_eos_threshold": 1.0,
  "punct_kv_mode": 1,
  "eos_penalty_only_last_chunk": false,
  "keep_kv_across_segments": true,
  "clear_kv_on_sentence_punct": false,
  "vad": {
    "model": "../../voice_app/assets/silero_vad.onnx",
    "threshold": 0.5,
    "min_silence_duration": 0.5,
    "min_speech_duration": 0.25,
    "window_size": 512,
    "max_speech_duration": 20.0,
    "sample_rate": 16000,
    "num_threads": 1,
    "buffer_size_seconds": 60.0
  },
  "circular_buffer_capacity": 480000,
  "max_pre_speech_samples": 8000
}
